# Frontend environment variables
# Backend URL for all API calls. Do NOT add /api at the end - the code adds it.
# (api.js -> fetch(`${BASE}/api${path}`))

# LOCAL DEVELOPMENT (default) - backend running on your machine
REACT_APP_API_URL=http://localhost:5000

# PRODUCTION (Railway/Render) - when deploying, comment the line above and uncomment this:
# REACT_APP_API_URL=https://sales-project-backend-b5oi.onrender.com

# ORIGINAL (Vite) variable names, kept for reference after converting to CRA:
# VITE_API_URL=http://localhost:5000
# VITE_API_URL=https://sales-project-backend-b5oi.onrender.com
